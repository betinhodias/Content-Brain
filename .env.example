# .env.example — Creative Brain
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o arquivo .env no git.

# ========================
# SUPABASE
# ========================
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ========================
# OPENROUTER (Gemma 4 Brain)
# ========================
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=google/gemma-4-26b-a4b-it
OPENROUTER_FALLBACK_MODEL=google/gemma-3-27b-it
OPENROUTER_SITE_URL=https://creative-brain.nosauto.com
OPENROUTER_APP_TITLE=Creative Brain

# ========================
# FREEPIK (Image Generation)
# ========================
# Nota: A chave de produção será do cliente (Calie Marketing).
# Para dev, use a chave de testes disponível.
FREEPIK_API_KEY=FPSX...
FREEPIK_API_URL=https://api.freepik.com/v1

# ========================
# EMBEDDINGS (para RAG do Brand Guide)
# ========================
# Opção A: OpenAI text-embedding-3-small (recomendado, $0.02/M tokens)
OPENAI_API_KEY=sk-...
EMBEDDINGS_MODEL=text-embedding-3-small
EMBEDDINGS_DIMENSIONS=1536

# ========================
# REMOTION (Video Rendering)
# ========================
REMOTION_LICENSE_KEY=     # Deixar vazio para dev (free tier)
REMOTION_CONCURRENCY=1    # Max renders paralelos por instância

# ========================
# FFMPEG
# ========================
# Deixar vazio para usar o PATH do sistema
FFMPEG_PATH=

# ========================
# APP
# ========================
PORT=3000
NODE_ENV=development
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_EXPIRES_IN=7d

# ========================
# STORAGE
# ========================
# Path prefix no Supabase Storage para assets gerados
STORAGE_BUCKET=creative-brain-assets
