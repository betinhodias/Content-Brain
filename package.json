{
  "name": "creative-brain-api",
  "version": "1.0.0",
  "description": "Creative Brain — Multi-tenant content production engine for marketing agencies",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "remotion:studio": "remotion studio src/remotion/Root.tsx",
    "remotion:render": "remotion render src/remotion/Root.tsx ReelComposition"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/jwt": "^8.0.1",
    "@fastify/multipart": "^8.3.0",
    "@fastify/rate-limit": "^9.1.0",
    "@remotion/bundler": "^4.0.462",
    "@remotion/renderer": "^4.0.462",
    "@supabase/supabase-js": "^2.45.4",
    "fastify": "^4.28.1",
    "fastify-plugin": "^4.5.1",
    "openai": "^4.67.3",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "remotion": "^4.0.462",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.14.0",
    "@typescript-eslint/parser": "^8.14.0",
    "eslint": "^9.14.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}