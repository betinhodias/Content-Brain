{
  "mode": "yolo",
  "granularity": "standard",
  "parallelization": {
    "enabled": true
  },
  "commit_docs": true,
  "model_profile": "balanced",
  "workflow": {
    "research": true,
    "plan_check": true,
    "verifier": true,
    "nyquist_validation": true,
